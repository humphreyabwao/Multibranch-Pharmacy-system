{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/node_modules/**",
      "automation/**",
      "firebase/**",
      "functions/**",
      "supabase/**",
      ".git/**",
      "README.md",
      "*.md"
    ],
    "rewrites": [
      {
        "source": "/api/fallback/write",
        "function": "supabaseFallbackWrite"
      },
      {
        "source": "/api/fallback/read",
        "function": "supabaseFallbackRead"
      },
      {
        "source": "/rider.html",
        "destination": "/rider.html"
      },
      {
        "source": "/login.html",
        "destination": "/login.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      },
      {
        "source": "**/*.@(html)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firebase/firestore.rules"
  },
  "storage": {
    "rules": "firebase/storage.rules"
  },
  "database": {
    "rules": "firebase/database.rules.json"
  }
}
