rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserProfile().role == role;
    }

    function isMasterEmail() {
      return isAuthenticated()
        && request.auth.token.email is string
        && request.auth.token.email == 'admin@pharmaflow.com';
    }

    function isSuperAdmin() {
      return hasRole('superadmin') || isMasterEmail();
    }

    function isAdminOrAbove() {
      return hasRole('superadmin') || hasRole('admin');
    }

    function belongsToBusiness(businessId) {
      return isAuthenticated() && getUserProfile().businessId == businessId;
    }

    function canAccessBusiness(businessId) {
      return isSuperAdmin() || belongsToBusiness(businessId);
    }

    function hasAnyModulePermission(moduleIds) {
      return isSuperAdmin()
        || (
          getUserProfile().permissionsConfigured != true
          && (
            !(getUserProfile().permissions is list)
            || getUserProfile().permissions.size() == 0
          )
        )
        || (
          getUserProfile().permissions is list
          && getUserProfile().permissions.hasAny(moduleIds)
        );
    }

    function canUseTenantModule(businessId, moduleIds) {
      return canAccessBusiness(businessId) && hasAnyModulePermission(moduleIds);
    }

    function branchCertificateUploadsEnabled(businessId) {
      return get(/databases/$(database)/documents/businesses/$(businessId)).data.branchCertificateUploadEnabled == true;
    }

    // ===== USER PROFILES =====
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isSuperAdmin() ||
        (
          hasRole('admin')
          && resource.data.businessId == getUserProfile().businessId
        )
      );

      // Profiles are provisioned only by an authorized administrator.
      allow create: if isAuthenticated() && (
        isSuperAdmin()
        || (
          hasRole('admin')
          && request.resource.data.businessId == getUserProfile().businessId
          && request.resource.data.role != 'superadmin'
          && request.resource.data.permissionsConfigured == true
          && request.resource.data.permissions is list
        )
      );
      // Self-edit is restricted to non-security profile fields.
      allow update: if isAuthenticated() && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['displayName', 'phone', 'photoURL', 'updatedAt']);

      // Superadmin: full edit access on any user profile
      allow update: if isSuperAdmin();

      // Admin: can edit users within the same business, cannot promote to superadmin
      allow update: if isAuthenticated()
        && hasRole('admin')
        && request.auth.uid != userId
        && resource.data.businessId == getUserProfile().businessId
        && request.resource.data.businessId == resource.data.businessId
        && resource.data.role != 'superadmin'
        && request.resource.data.role != 'superadmin'
        && request.resource.data.permissionsConfigured == true
        && request.resource.data.permissions is list;

      // Delete user profiles:
      // - superadmin can delete any non-self profile
      // - admin can delete non-superadmin users in own business (non-self)
      allow delete: if isAuthenticated() && (
        (
          isSuperAdmin()
          && request.auth.uid != userId
        )
        || (
          hasRole('admin')
          && request.auth.uid != userId
          && resource.data.businessId == getUserProfile().businessId
          && resource.data.role != 'superadmin'
        )
      );
    }

    // ===== BUSINESSES (Franchises) =====
    match /businesses/{businessId} {
      allow read: if isSuperAdmin() || belongsToBusiness(businessId);
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin()
        || (
          isAdminOrAbove()
          && belongsToBusiness(businessId)
          && hasAnyModulePermission(['settings'])
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'branchCertificateUploadEnabled',
            'branchCertificatePermissionUpdatedAt',
            'branchCertificatePermissionUpdatedBy'
          ])
        );
      allow delete: if isSuperAdmin();

      // ── Sales (POS) — all staff can create, admin+ to edit/delete ──
      match /sales/{saleId} {
        allow read: if canUseTenantModule(businessId, ['dashboard', 'pharmacy', 'wholesale', 'reports', 'accounts']);
        allow create: if canUseTenantModule(businessId, ['pharmacy', 'wholesale', 'patients']);
        allow update, delete: if canUseTenantModule(businessId, ['pharmacy', 'wholesale']) && isAdminOrAbove();
      }

      // ── Inventory — all staff can create & update stock, admin+ to delete ──
      match /inventory/{itemId} {
        allow read: if canUseTenantModule(businessId, ['dashboard', 'pharmacy', 'inventory', 'disposals', 'dda-register', 'my-orders', 'wholesale', 'patients', 'reports']);
        allow create, update: if canUseTenantModule(businessId, ['inventory', 'pharmacy', 'disposals', 'dda-register', 'my-orders', 'wholesale', 'patients']);
        allow delete: if canUseTenantModule(businessId, ['inventory']) && isAdminOrAbove();
      }

      // ── Patients — all staff can register & update, admin+ to delete ──
      match /patients/{patientId} {
        allow read: if canUseTenantModule(businessId, ['dashboard', 'patients', 'reports']);
        allow create, update: if canUseTenantModule(businessId, ['patients']);
        allow delete: if canUseTenantModule(businessId, ['patients']) && isAdminOrAbove();
      }

      // ── Patient Bills — all staff can create & update, admin+ to delete ──
      match /patient_bills/{billId} {
        allow read: if canUseTenantModule(businessId, ['patients', 'reports', 'accounts']);
        allow create, update: if canUseTenantModule(businessId, ['patients']);
        allow delete: if canUseTenantModule(businessId, ['patients']) && isAdminOrAbove();
      }

      // ── Patient Records (clinical) — all staff can create & update ──
      match /patient_records/{recordId} {
        allow read: if canUseTenantModule(businessId, ['patients']);
        allow create, update: if canUseTenantModule(businessId, ['patients']);
        allow delete: if canUseTenantModule(businessId, ['patients']) && isAdminOrAbove();
      }

      // ── Prescriptions — all staff can create ──
      match /prescriptions/{prescriptionId} {
        allow read: if canUseTenantModule(businessId, ['dashboard', 'pharmacy', 'patients', 'reports']);
        allow create: if canUseTenantModule(businessId, ['pharmacy', 'patients']);
        allow update, delete: if canUseTenantModule(businessId, ['pharmacy', 'patients']) && isAdminOrAbove();
      }

      // ── Expenses — all staff can create, admin+ to edit/delete ──
      match /expenses/{expenseId} {
        allow read: if canUseTenantModule(businessId, ['dashboard', 'expenses', 'reports', 'accounts']);
        allow create: if canUseTenantModule(businessId, ['expenses']);
        allow update, delete: if canUseTenantModule(businessId, ['expenses']) && isAdminOrAbove();
      }

      // ── Orders (My Orders) — all staff can create & update, admin+ to delete ──
      match /orders/{orderId} {
        allow read: if canUseTenantModule(businessId, ['dashboard', 'my-orders', 'supplier', 'reports']);
        allow create, update: if canUseTenantModule(businessId, ['my-orders']);
        allow delete: if canUseTenantModule(businessId, ['my-orders']) && isAdminOrAbove();
      }

      // ── DDA Register — all staff can create ──
      match /dda_register/{entryId} {
        allow read: if canUseTenantModule(businessId, ['dda-register', 'reports']);
        allow create: if canUseTenantModule(businessId, ['dda-register']);
        allow update, delete: if canUseTenantModule(businessId, ['dda-register']) && isAdminOrAbove();
      }

      // ── Suppliers — admin+ only ──
      match /suppliers/{supplierId} {
        allow read: if canUseTenantModule(businessId, ['supplier', 'my-orders']);
        allow create, update, delete: if canUseTenantModule(businessId, ['supplier']) && isAdminOrAbove();
      }

      // ── Wholesale Orders — admin+ to create/edit/delete, rider token for dispatch updates ──
      match /wholesale_orders/{wholesaleId} {
        allow read: if canUseTenantModule(businessId, ['dashboard', 'wholesale', 'reports']);
        allow create: if canUseTenantModule(businessId, ['wholesale']) && isAdminOrAbove();
        allow update: if canUseTenantModule(businessId, ['wholesale']) && isAdminOrAbove();
        allow delete: if canUseTenantModule(businessId, ['wholesale']) && isAdminOrAbove();
        // Allow unauthenticated rider to read & update dispatch status via token
        allow get: if resource.data.dispatch.riderToken is string && resource.data.dispatch.riderToken.size() > 0;
        allow update: if resource.data.dispatch.riderToken is string
          && resource.data.dispatch.riderToken.size() > 0
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['dispatch', 'updatedAt']);
      }

      // ── Activity Log — all staff can create (logging), admin+ to delete ──
      match /activity_log/{logId} {
        allow read: if canUseTenantModule(businessId, ['activity-log', 'dashboard']);
        allow create: if canAccessBusiness(businessId);
        allow update, delete: if canUseTenantModule(businessId, ['activity-log']) && isAdminOrAbove();
      }

      // ── Medication Refills — all staff can create & update, admin+ to delete ──
      match /medication_refills/{refillId} {
        allow read: if canUseTenantModule(businessId, ['dashboard', 'medication-refill']);
        allow create, update: if canUseTenantModule(businessId, ['medication-refill']);
        allow delete: if canUseTenantModule(businessId, ['medication-refill']) && isAdminOrAbove();
      }

      // ── Reports — admin+ only ──
      match /reports/{reportId} {
        allow read: if canUseTenantModule(businessId, ['reports']);
        allow create, update, delete: if canUseTenantModule(businessId, ['reports']) && isAdminOrAbove();
      }

      // Human Resource: admin+ only. Reports can read HR data for exports.
      match /hr_staff/{staffId} {
        allow read: if canUseTenantModule(businessId, ['human-resource', 'reports']) && isAdminOrAbove();
        allow create, update, delete: if canUseTenantModule(businessId, ['human-resource']) && isAdminOrAbove();
      }

      match /hr_staff_profiles/{profileId} {
        allow read: if canUseTenantModule(businessId, ['human-resource', 'reports']) && isAdminOrAbove();
        allow create, update, delete: if canUseTenantModule(businessId, ['human-resource']) && isAdminOrAbove();
      }

      match /hr_payroll/{payrollId} {
        allow read: if canUseTenantModule(businessId, ['human-resource', 'reports']) && isAdminOrAbove();
        allow create, update, delete: if canUseTenantModule(businessId, ['human-resource']) && isAdminOrAbove();
      }

      match /hr_advances/{advanceId} {
        allow read: if canUseTenantModule(businessId, ['human-resource', 'reports']) && isAdminOrAbove();
        allow create, update, delete: if canUseTenantModule(businessId, ['human-resource']) && isAdminOrAbove();
      }

      // ── Accounts — admin+ to write, superadmin to delete ──
      match /accounts/{accountId} {
        allow read: if canUseTenantModule(businessId, ['accounts']);
        allow create, update: if canUseTenantModule(businessId, ['accounts']) && isAdminOrAbove();
        allow delete: if canUseTenantModule(businessId, ['accounts']) && isSuperAdmin();
      }

      // ── Messages — all staff can read/create/update ──
      match /messages/{messageId} {
        allow read: if canAccessBusiness(businessId);
        allow create, update: if canAccessBusiness(businessId);
        allow delete: if canAccessBusiness(businessId) && isAdminOrAbove();
      }

      // ── Message History — all staff can read/create/update, admin+ to delete ──
      match /message_history/{historyId} {
        allow read: if canAccessBusiness(businessId);
        allow create, update: if canAccessBusiness(businessId);
        allow delete: if canAccessBusiness(businessId) && isAdminOrAbove();
      }

      // ── Notifications — all staff can read/create/update ──
      match /notifications/{notificationId} {
        allow read: if canAccessBusiness(businessId);
        allow create, update: if canAccessBusiness(businessId);
        allow delete: if canAccessBusiness(businessId) && isAdminOrAbove();
      }

      // ── Support Tickets — branch creates/tracks, superadmin resolves ──
      match /tickets/{ticketId} {
        allow read: if canUseTenantModule(businessId, ['support-tickets']);
        allow create: if canUseTenantModule(businessId, ['support-tickets'])
          && request.resource.data.businessId == businessId;
        allow update: if isSuperAdmin()
          || (
            canUseTenantModule(businessId, ['support-tickets'])
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['title', 'description', 'category', 'priority', 'contactPhone', 'reference', 'updatedAt', 'lastUpdatedBy'])
          );
        allow delete: if isSuperAdmin();
      }

      // ── Settings (retention, etc.) — admin+ to read/write ──
      match /settings/{settingId} {
        allow read: if canUseTenantModule(businessId, ['settings', 'activity-log']);
        allow create, update: if canUseTenantModule(businessId, ['settings', 'activity-log']) && isAdminOrAbove();
        allow delete: if canUseTenantModule(businessId, ['settings']) && isSuperAdmin();
      }

      // ── Stock History — read for all, write for admin+ ──
      match /stock_history/{entryId} {
        allow read: if canUseTenantModule(businessId, ['inventory', 'my-orders', 'reports']);
        allow create: if canUseTenantModule(businessId, ['inventory', 'pharmacy', 'disposals', 'my-orders', 'wholesale']);
        allow delete: if canUseTenantModule(businessId, ['inventory']) && isSuperAdmin();
      }

      // Inventory disposals — expired batches are quarantined automatically;
      // staff can record damage and complete physical disposal.
      match /disposals/{disposalId} {
        allow read: if canUseTenantModule(businessId, ['dashboard', 'inventory', 'disposals', 'reports']);
        allow create: if canUseTenantModule(businessId, ['inventory', 'disposals'])
          && request.resource.data.productId is string
          && request.resource.data.productName is string
          && request.resource.data.quantity is int
          && request.resource.data.quantity > 0
          && request.resource.data.reason in [
            'expired',
            'broken',
            'damaged',
            'contaminated',
            'recalled',
            'spillage',
            'other'
          ]
          && request.resource.data.source in ['automatic', 'manual']
          && request.resource.data.status == 'pending';
        allow update: if canUseTenantModule(businessId, ['inventory', 'disposals'])
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'disposalMethod',
            'disposalDate',
            'disposalNotes',
            'disposedBy',
            'disposedByEmail',
            'disposedByUid',
            'disposedAt',
            'updatedAt'
          ])
          && request.resource.data.status == 'disposed'
          && request.resource.data.disposedBy is string
          && request.resource.data.disposedByEmail is string
          && request.resource.data.disposedByUid is string
          && request.resource.data.disposedAt is string;
        allow delete: if canUseTenantModule(businessId, ['disposals']) && isAdminOrAbove();
      }

      // ── Client Leads — wholesale client management ──
      match /client_leads/{clientId} {
        allow read: if canUseTenantModule(businessId, ['wholesale']);
        allow create, update: if canUseTenantModule(businessId, ['wholesale']);
        allow delete: if canUseTenantModule(businessId, ['wholesale']) && isAdminOrAbove();
      }

      // ── Riders — delivery riders management + public update for delivery count ──
      match /riders/{riderId} {
        allow read: if canUseTenantModule(businessId, ['wholesale']);
        allow create, update: if canUseTenantModule(businessId, ['wholesale']);
        allow delete: if canUseTenantModule(businessId, ['wholesale']) && isAdminOrAbove();
        // Allow unauthenticated rider page to update delivery stats
        allow get: if true;
        allow update: if request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['deliveryCount', 'status', 'updatedAt']);
      }
    }

    // ===== RIDER SESSIONS (public read for shareable rider links) =====
    match /rider_sessions/{token} {
      allow get: if true;
      allow list: if false;
      allow create, update: if isSuperAdmin()
        || (
          isAuthenticated()
          && request.resource.data.businessIds is list
          && request.resource.data.businessIds.size() == 1
          && request.resource.data.businessIds[0] == getUserProfile().businessId
          && hasAnyModulePermission(['wholesale'])
        );
    }

    // ===== GLOBAL ADMIN CONFIG =====
    match /superadmin/{docId} {
      allow read, write: if isSuperAdmin();
    }

    // ===== SYSTEM CONFIG (auto-reminders, etc.) =====
    match /system_config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ===== FRANCHISE ALERTS =====
    match /franchise_alerts/{alertId} {
      allow read: if isSuperAdmin()
        || (isAuthenticated() && belongsToBusiness(resource.data.businessId));
      allow create, delete: if isSuperAdmin();
      // Admins+ can update alert state; branch users can only dismiss alerts explicitly marked dismissible.
      allow update: if isSuperAdmin()
        || (
          isAuthenticated()
          && belongsToBusiness(resource.data.businessId)
          && resource.data.allowUserDismiss != false
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
          && request.resource.data.status == 'dismissed'
        );
    }

    // ===== CENTRAL SUPPORT TICKET COPIES =====
    match /support_tickets/{ticketId} {
      allow read: if isSuperAdmin()
        || (
          isAuthenticated()
          && belongsToBusiness(resource.data.businessId)
          && hasAnyModulePermission(['support-tickets'])
        );
      allow create: if isAuthenticated()
        && request.resource.data.businessId is string
        && (
          isSuperAdmin()
          || (
            belongsToBusiness(request.resource.data.businessId)
            && hasAnyModulePermission(['support-tickets'])
          )
        );
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ===== BRANCH PORTAL: BILLING DOCUMENTS =====
    match /branch_finance_docs/{docId} {
      allow read: if isSuperAdmin()
        || (
          isAuthenticated()
          && belongsToBusiness(resource.data.businessId)
          && hasAnyModulePermission(['branch-portal'])
        );
      allow create, update, delete: if isSuperAdmin();
    }

    // ===== BRANCH PORTAL: COMMUNICATIONS =====
    match /branch_communications/{messageId} {
      allow read: if isSuperAdmin()
        || (
          isAuthenticated()
          && belongsToBusiness(resource.data.businessId)
          && hasAnyModulePermission(['branch-portal'])
        );
      allow create: if isAuthenticated()
        && request.resource.data.businessId is string
        && (
          isSuperAdmin()
          || (
            belongsToBusiness(request.resource.data.businessId)
            && hasAnyModulePermission(['branch-portal'])
          )
        );
      allow update, delete: if isSuperAdmin();
    }

    // ===== BRANCH PORTAL: CONTRACTS =====
    match /branch_contracts/{contractId} {
      allow read: if isSuperAdmin()
        || (
          isAuthenticated()
          && belongsToBusiness(resource.data.businessId)
          && hasAnyModulePermission(['branch-portal'])
        );
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin()
        || (
          isAuthenticated()
          && belongsToBusiness(resource.data.businessId)
          && hasAnyModulePermission(['branch-portal'])
          && request.resource.data.businessId == resource.data.businessId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'signedFileUrl',
            'signedFileName',
            'signedFileType',
            'signatureDataUrl',
            'signedBy',
            'signedAt',
            'status',
            'updatedAt'
          ])
        );
    }

    // ===== BRANCH PORTAL: CERTIFICATES =====
    // Superadmin grants upload access on the business document. Branch users can
    // then create image-only certificate records for their own branch.
    match /branch_certificates/{certificateId} {
      allow read: if isSuperAdmin()
        || (
          isAuthenticated()
          && belongsToBusiness(resource.data.businessId)
          && hasAnyModulePermission(['branch-portal'])
        );
      allow create: if isAuthenticated()
        && request.resource.data.businessId is string
        && belongsToBusiness(request.resource.data.businessId)
        && hasAnyModulePermission(['branch-portal'])
        && branchCertificateUploadsEnabled(request.resource.data.businessId)
        && request.resource.data.imageUrl is string
        && request.resource.data.imageName is string
        && request.resource.data.imageType is string
        && request.resource.data.imageType.matches('image/(png|jpeg|webp)')
        && request.resource.data.certificateType in [
          'pharmacy_license',
          'waste_facility',
          'business_permit',
          'professional_license',
          'inspection_certificate',
          'other'
        ]
        && request.resource.data.title is string
        && request.resource.data.uploadedBy is string;
      allow update, delete: if isSuperAdmin();
    }

    // Allow superadmin collection-group ticket queue reads.
    match /{path=**}/tickets/{ticketId} {
      allow read: if isSuperAdmin();
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
