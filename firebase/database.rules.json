{
  "rules": {
    ".read": false,
    ".write": false,

    "_meta": {
      "note": {
        ".read": false,
        ".write": false
      }
    },

    "users": {
      "$userId": {
        ".read": "auth != null && (auth.uid == $userId || auth.token.email == 'admin@pharmaflow.com')",
        ".write": "auth != null && (auth.uid == $userId || auth.token.email == 'admin@pharmaflow.com')",

        "role": {
          ".validate": "newData.isString() && newData.val().matches(/^(superadmin|admin|staff)$/)"
        },
        "businessId": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "$other": {
          ".validate": "newData.val() == null || newData.isString() || newData.isNumber() || newData.isBoolean() || newData.hasChildren()"
        }
      }
    },

    "businesses": {
      "$businessId": {
        ".read": "auth != null",
        ".write": "auth != null",

        "wholesale_orders": {
          "$wholesaleId": {
            "dispatch": {
              ".write": "(auth != null) || (auth == null && data.child('riderToken').isString() && newData.child('riderToken').isString() && data.child('riderToken').val() == newData.child('riderToken').val())"
            }
          }
        },

        "riders": {
          "$riderId": {
            "deliveryCount": {
              ".validate": "!newData.exists() || newData.isNumber()"
            },
            "status": {
              ".validate": "!newData.exists() || (newData.isString() && newData.val().matches(/^(active|inactive|on_delivery)$/))"
            }
          }
        }
      }
    },

    "rider_sessions": {
      "$token": {
        ".read": true,
        ".write": "auth != null"
      }
    },

    "superadmin": {
      "$docId": {
        ".read": "auth != null && auth.token.email == 'admin@pharmaflow.com'",
        ".write": "auth != null && auth.token.email == 'admin@pharmaflow.com'"
      }
    },

    "system_config": {
      "$docId": {
        ".read": "auth != null",
        ".write": "auth != null && auth.token.email == 'admin@pharmaflow.com'"
      }
    },

    "franchise_alerts": {
      "$alertId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}